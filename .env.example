# ===================================================================
# SOLANA TRADING BOT - CONFIGURATION
# ===================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ===================================================================
# WALLET
# ===================================================================
# Your wallet's base58 private key (keep this secret!)
WALLET_PRIVATE_KEY=

# ===================================================================
# APIS - Helius (RPC)
# ===================================================================
# Get your key at: https://www.helius.xyz/
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Backup RPC (public endpoint, no key needed)
BACKUP_RPC_URL=https://api.mainnet-beta.solana.com

# ===================================================================
# APIS - Jupiter
# ===================================================================
# Get your API key at: https://jup.ag/
JUPITER_API_KEY=

# ===================================================================
# APIS - Security (Optional but Recommended)
# ===================================================================
# GoPlus Security API - https://gopluslabs.io/
# Free tier: 100 requests/day
GOPLUS_API_KEY=

# RugCheck - No API key needed (free)
RUGCHECK_ENABLED=true

# Token Sniffer - Optional cross-verification
TOKEN_SNIFFER_API_KEY=

# ===================================================================
# TRADING STRATEGY
# ===================================================================
# Initial trading capital (in SOL)
INITIAL_SOL_AMOUNT=0.1

# The base amount that gets compounded
BASE_SOL=0.1

# How often to scan for new tokens (seconds)
SCAN_INTERVAL_SECONDS=5

# Maximum number of concurrent open positions
MAX_POSITIONS=1

# ===================================================================
# RISK MANAGEMENT
# ===================================================================
# Stop loss: Exit if position drops this percentage (40%)
STOP_LOSS_PERCENTAGE=40

# Trailing stop: Distance from peak as percentage (15%)
TRAILING_STOP_PERCENTAGE=15

# Trailing stop: Activate only after this gain (100%)
TRAILING_STOP_ACTIVATION_PERCENTAGE=100

# Maximum time to hold a position (hours)
MAX_HOLD_TIME_HOURS=4

# ===================================================================
# LIQUIDITY REQUIREMENTS
# ===================================================================
# Minimum liquidity in USD
MIN_LIQUIDITY_USD=15000

# Minimum SOL amount in pool
MIN_POOL_SOL_AMOUNT=50

# ===================================================================
# SLIPPAGE TOLERANCE
# ===================================================================
# Entry slippage in basis points (100 = 1%)
ENTRY_SLIPPAGE_BPS=100

# Exit slippage in basis points (300 = 3%)
EXIT_SLIPPAGE_BPS=300

# ===================================================================
# DATABASE
# ===================================================================
# Path to SQLite database file
DATABASE_PATH=/app/data/bot.db

# ===================================================================
# TRADING MODE
# ===================================================================
# Options: paper, live
# PAPER: Simulated trading with real data (no risk)
# LIVE: Real trading with actual funds (be careful!)
TRADING_MODE=paper

# ===================================================================
# LOGGING
# ===================================================================
# Options: debug, info, warn, error
LOG_LEVEL=info

# Log to file?
LOG_TO_FILE=true

# Log file path
LOG_FILE_PATH=/app/logs/bot.log

# ===================================================================
# DEXSCREENER CLI (Optional)
# ===================================================================
# If using the DexScreener CLI MCP tool
DEXSCREENER_CLI_PATH=
