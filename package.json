{
  "name": "solana-trading-bot",
  "version": "1.0.0",
  "description": "Solana automated trading bot with Jupiter integration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:paper": "tsx src/index.ts start:paper",
    "start:live": "tsx src/index.ts start:live",
    "report": "tsx src/index.ts report",
    "status": "tsx src/index.ts status",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install"
  },
  "dependencies": {
    "@jup-ag/api": "^6.0.48",
    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^9.6.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "dotenv": "^17.3.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/bn.js": "^5.1.5",
    "@types/bs58": "^4.0.4",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
